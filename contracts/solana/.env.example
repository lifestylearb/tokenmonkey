# Solana private key as a JSON array of bytes (from solana-keygen)
# Example: [12,34,56,78,...]
SOLANA_PRIVATE_KEY=

# Solana RPC URL
# Mainnet: https://api.mainnet-beta.solana.com
# Devnet:  https://api.devnet.solana.com
# Testnet: https://api.testnet.solana.com
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Token metadata URI (update after uploading metadata.json to permanent storage)
# This should point to the hosted metadata.json file (e.g., on Arweave or IPFS)
TOKEN_METADATA_URI=https://tokenmonkey.io/metadata.json
